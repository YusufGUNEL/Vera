# Bu dosyayi .env olarak kopyalayin ve degerleri doldurun.
# .env dosyasi git'e commit edilmez (.gitignore'da).

# Google AI Studio'dan alin: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Kullanilacak model (varsayilan: gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-2.0-flash-exp

# Opsiyonel canli veri endpoint'leri
# Bos birakilirsa uygulama cache + local live mock refresh ile calisir
HOME_FEED_URL=
SECURITY_FEED_URL=

# Firebase (opsiyonel ama Firebase baglantisi icin gerekli)
# Bu alanlar bos kalirsa uygulama Firebase'i devreye almaz ve local mode'da calisir.
FIREBASE_API_KEY=
FIREBASE_APP_ID_ANDROID=
FIREBASE_APP_ID_WEB=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_AUTH_DOMAIN=
FIREBASE_MEASUREMENT_ID=
